@page "/catalogue"
@using PimFront.Models
@using PimFront.Services
@inject PimApiClient Api
@inject NavigationManager Nav

<PageTitle>Catalogue — PIM Vitajardin</PageTitle>

<div class="catalogue">

    <div class="catalogue__header">
        <h1>Catalogue végétal</h1>
        <p class="catalogue__subtitle">@_total.ToString("N0") taxons</p>
    </div>

    <!-- Barre de recherche -->
    <div class="catalogue__search">
        <input type="search"
               class="search-input"
               placeholder="Rechercher un taxon, synonyme, nom commercial..."
               @bind="_query"
               @bind:event="oninput"
               @onkeyup="OnSearchKeyUp" />
        @if (_isSearching)
        {
            <span class="search-spinner">⏳</span>
        }
    </div>

    <!-- Filtres catégorie -->
    @if (_arborescence != null)
    {
        <div class="catalogue__filters">
            <button class="filter-btn @(_selectedCategorie == null ? "active" : "")"
                    @onclick="() => SelectCategorie(null)">
                Toutes
            </button>
            @foreach (var niv1 in _arborescence)
            {
                foreach (var niv2 in niv1.Enfants)
                {
                    <button class="filter-btn @(_selectedCategorie == niv2.Id ? "active" : "")"
                            @onclick="() => SelectCategorie(niv2.Id)">
                        @niv2.Libelle
                    </button>
                }
            }
        </div>
    }

    <!-- Résultats de recherche -->
    @if (_searchResponse != null)
    {
        <div class="catalogue__results-header">
            <span>@_searchResponse.TotalHits résultat(s) pour « @_query »</span>
            <button class="btn-clear" @onclick="ClearSearch">✕ Effacer</button>
        </div>
        <div class="taxon-grid">
            @foreach (var r in _searchResponse.Results.Taxons)
            {
                <TaxonCard Id="@(r.Id ?? 0)"
                           GenreLibelle="@r.Label"
                           SeoName="@r.SeoName"
                           CategorieLibelle="@r.Categorie"
                           StatutConfiance="verifie" />
            }
        </div>
    }
    else if (_taxons != null)
    {
        <div class="taxon-grid">
            @foreach (var t in _taxons)
            {
                <TaxonCard Id="t.Id"
                           GenreLibelle="@t.GenreLibelle"
                           EspeceLabel="@t.EspeceLabel"
                           SousEspeceLabel="@t.SousEspeceLabel"
                           VarieteLabel="@t.VarieteLabel"
                           Cultivar="@t.Cultivar"
                           NomCommercial="@t.NomCommercial"
                           SeoName="@t.SeoName"
                           CategorieLibelle="@GetCategorieLibelle(t.CategorieId)"
                           StatutConfiance="@t.StatutConfiance" />
            }
        </div>

        <div class="pagination">
            <button class="btn-page" disabled="@(_page <= 1)" @onclick="PrevPage">← Précédent</button>
            <span class="pagination__info">Page @_page / @_totalPages</span>
            <button class="btn-page" disabled="@(_page >= _totalPages)" @onclick="NextPage">Suivant →</button>
        </div>
    }
    else
    {
        <div class="loading">Chargement...</div>
    }

</div>

@code {
    private List<TaxonListItem>? _taxons;
    private SearchResponse? _searchResponse;
    private List<CategorieArborescence>? _arborescence;
    private Dictionary<int, string> _catCache = new();

    private string _query = "";
    private int? _selectedCategorie;
    private int _page = 1;
    private int _pageSize = 24;
    private int _total = 0;
    private int _totalPages = 1;
    private bool _isSearching = false;
    private CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync()
    {
        var arboTask = Api.GetArborescenceAsync();
        var taxonsTask = LoadTaxonsAsync();
        await Task.WhenAll(arboTask, taxonsTask);
        _arborescence = await arboTask;

        // Construire le cache catégories
        if (_arborescence != null)
        {
            foreach (var niv1 in _arborescence)
                foreach (var niv2 in niv1.Enfants)
                    _catCache[niv2.Id] = niv2.Libelle;
        }
    }

    private string? GetCategorieLibelle(int? id) =>
        id.HasValue && _catCache.TryGetValue(id.Value, out var lib) ? lib : null;

    private async Task LoadTaxonsAsync()
    {
        var result = await Api.GetTaxonsAsync(_page, _pageSize, _selectedCategorie);
        if (result != null)
        {
            _taxons = result.Items;
            _total = result.Total;
            _totalPages = result.TotalPages;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        if (string.IsNullOrWhiteSpace(_query)) { _searchResponse = null; return; }
        if (_query.Length < 2) return;

        try
        {
            await Task.Delay(350, token);
            _isSearching = true;
            StateHasChanged();
            _searchResponse = await Api.SearchAsync(_query, limit: 50, ct: token);
        }
        catch (OperationCanceledException) { }
        finally { _isSearching = false; StateHasChanged(); }
    }

    private void ClearSearch() { _query = ""; _searchResponse = null; }

    private async Task SelectCategorie(int? id)
    {
        _selectedCategorie = id;
        _page = 1;
        _searchResponse = null;
        _query = "";
        await LoadTaxonsAsync();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadTaxonsAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadTaxonsAsync(); } }
}
